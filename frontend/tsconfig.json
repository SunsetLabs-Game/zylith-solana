{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": ["./src/*"],
      "@zylith/sdk": ["../sdk/src"]
    },
    "baseUrl": "."
  },
  "include": ["src"],
  "references": [{ "path": "../sdk" }]
}
