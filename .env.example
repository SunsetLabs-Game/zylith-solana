VITE_RPC_URL=https://api.testnet.solana.com

# --- Program IDs ---
COORDINATOR_PROGRAM_ID=73ZjypnCmuuTrg5wLRTZxUpj6wv6y2qvwGR97pHnL4Zy
POOL_PROGRAM_ID=73ZjypnCmuuTrg5wLRTZxUpj6wv6y2qvwGR97pHnL4Zy
VITE_PROGRAM_ID=73ZjypnCmuuTrg5wLRTZxUpj6wv6y2qvwGR97pHnL4Zy

# --- ASP (Anonymous Service Provider) Configuration ---
ASP_HOST=127.0.0.1
ASP_PORT=3000
